# =============================================================================
# Lumively Python Admin — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# =============================================================================

# --- Core ---
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/lumively?sslmode=require"

# --- Admin Authentication ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
JWT_SECRET=generate_a_random_64_char_hex_string_here


# --- OpenRouter API (LLM for AI copy & chatbot) ---
# Sign up at https://openrouter.ai/ and create an API key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# --- Meta Graph API (Facebook + Instagram) ---
# Create a Facebook App and generate a Page Access Token
# Docs: https://developers.facebook.com/docs/pages/getting-started
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
FB_PAGE_ID=your_facebook_page_id
IG_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# --- Resend API (Email) ---
# Sign up at https://resend.com/ and verify your domain
# IMPORTANT: You must verify lumively.com domain in Resend dashboard
# by adding the required DNS records (MX, SPF, DKIM)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL="Lumively <support@lumively.com>"

# --- CORS (comma-separated origins or ["*"]) ---
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Gemini (legacy, optional) ---
# GEMINI_API_KEY=your_gemini_key_if_needed
