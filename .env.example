# =============================================================================
# Organic Marketing AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control!
# =============================================================================

# --- Core ---
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/organicai?sslmode=require"

# --- Admin Authentication ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
JWT_SECRET=generate_a_random_64_char_hex_string_here

# --- OpenRouter API (LLM for AI copy & chatbot) ---
# Sign up at https://openrouter.ai/ and create an API key
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# --- Meta Graph API (Facebook + Instagram) ---
# Create a Facebook App and generate a Page Access Token
# Docs: https://developers.facebook.com/docs/pages/getting-started
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here
FB_PAGE_ID=your_facebook_page_id
IG_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# --- Resend API (Email) ---
# Sign up at https://resend.com/ and verify your domain
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL="Organic Marketing AI <support@organicmarketing.ai>"

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- Twitter/X API (Optional) ---
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=

# --- LinkedIn API (Optional) ---
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_ID=

# --- CORS (comma-separated origins) ---
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
